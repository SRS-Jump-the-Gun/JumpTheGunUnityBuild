  textColor: {r: 1, g: 1, b: 1, a: 1}
  dialogueLines:
  - speakerName: 'Narrator:'
    text: "It all started on a quiet weekend afternoon in the Morris household. Father
      and daughter sat side by side on the couch, two steaming Star Wars mugs and
      a plate of peeled oranges resting on the table beside them. \r\n"
    voiceLine: {fileID: 0}
  - speakerName: 'Narrator:'
    text: "Sunlight streaked in between the half-closed blue curtains onto the wooden
      floor. A few animal plushes and cotton throw pillows were scattered around
      the couch area. On the wall, framed and arranged with great care, were a child\u2019s
      crayon and watercolor drawings. \r\n\r\n"
    voiceLine: {fileID: 0}
  ambientSound: {fileID: 8300000, guid: c04dcfddfdab34461af2b4c29ea2e24e, type: 3}
